/dts-v1/;

#include "ipq5018.dtsi"
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>

/ {
	model = "CMCC RAX3000Q";
	compatible = "cmcc,rax3000q", "qcom,ipq5018";

	aliases {
		serial0 = &blsp1_uart1;
		led-boot = &led_system_green;
		led-failsafe = &led_system_red;
		led-running = &led_system_green;
		led-upgrade = &led_system_blue;
	};

	chosen {
		stdout-path = "serial0:115200n8";
	};

	leds {
		compatible = "gpio-leds";

		led_system_red: system_red {
			label = "red:system";
			gpios = <&tlmm 24 GPIO_ACTIVE_HIGH>;
		};

		led_system_green: system_green {
			label = "green:system";
			gpios = <&tlmm 19 GPIO_ACTIVE_HIGH>;
		};

		led_system_blue: system_blue {
			label = "blue:internet";
			gpios = <&tlmm 17 GPIO_ACTIVE_HIGH>;
		};
	};

	keys {
		compatible = "gpio-keys";

		button_reset {
			label = "reset";
			gpios = <&tlmm 23 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_RESTART>;
			debounce-interval = <60>;
		};

		button_mesh {
			label = "mesh";
			gpios = <&tlmm 38 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_WPS_BUTTON>;
			debounce-interval = <60>;
		};
	};
};

&blsp1_uart1 {
	pinctrl-0 = <&blsp_uart0_pins>;
	pinctrl-names = "default";
	status = "okay";
};

/* 现代主线网卡驱动 EDMA */
&edma {
	status = "okay";
};

/* CPU 网口连接到 QCA8337 交换机芯片 */
&gmac1 {
	status = "okay";
	phy-mode = "sgmii";
	label = "cpu";

	fixed-link {
		speed = <1000>;
		full-duplex;
	};
};

/* 现代标准的 DSA 交换机芯片配置 */
&mdio {
	status = "okay";
	pinctrl-0 = <&mdio1_pins>;
	pinctrl-names = "default";
	reset-gpios = <&tlmm 26 GPIO_ACTIVE_LOW>;

	switch@10 {
		compatible = "qcom,qca8337";
		reg = <0x10>;

		ports {
			#address-cells = <1>;
			#size-cells = <0>;

			port@0 {
				reg = <0>;
				label = "cpu";
				ethernet = <&gmac1>;
				phy-mode = "sgmii";

				fixed-link {
					speed = <1000>;
					full-duplex;
				};
			};

			/* 映射 WAN 口 */
			port@1 {
				reg = <1>;
				label = "wan";
			};

			/* 映射 LAN1 - LAN3 口 */
			port@2 {
				reg = <2>;
				label = "lan1";
			};

			port@4 {
				reg = <4>;
				label = "lan2";
			};

			port@5 {
				reg = <5>;
				label = "lan3";
			};
		};
	};
};

&qpic_bam {
	status = "okay";
};

/* 闪存节点现代化改造：使用 SMEM 动态解析 */
&spi0 {
	status = "okay";

	flash@0 {
		compatible = "spi-nand";
		reg = <0>;
		#address-cells = <1>;
		#size-cells = <1>;
		spi-max-frequency = <50000000>;

		/* 引入高通标准的 SMEM 动态分区解析器，取代硬编码分区 */
		partitions {
			compatible = "qcom,smem-part";
		};
	};
};

/* UBI 自动挂载声明：接管 SMEM 解析出的 rootfs 块 */
&smem_uboot_part {
	compatible = "fixed-partitions";
	#address-cells = <1>;
	#size-cells = <1>;

	partition@rootfs {
		compatible = "ubi";
		label = "rootfs";
	};
};

&tsens {
	status = "okay";
};

/* 抛弃高通私有的闭源大块，直接使用开源 ath11k 无线生态 */
&wifi0 {
	status = "okay";
};

&wifi1 {
	status = "okay";
};
