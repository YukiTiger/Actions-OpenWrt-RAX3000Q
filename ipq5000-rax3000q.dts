/dts-v1/;

#include "ipq5018.dtsi"
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>

/ {
	model = "CMCC RAX3000Q";
	compatible = "cmcc,rax3000q", "qcom,ipq5018";

	#address-cells = <2>;
	#size-cells = <2>;
	interrupt-parent = <&intc>;

	aliases {
		serial0 = &blsp1_uart1;

		ethernet0 = &dp1;
		ethernet1 = &dp2;

		led-boot = &led_status_green;
		led-failsafe = &led_status_red;
		led-running = &led_status_green;
		led-upgrade = &led_status_blue;
	};

	chosen {
		bootargs-append = " root=/dev/ubiblock0_1 coherent_pool=2M";
		stdout-path = "serial0:115200n8";
	};

	reserved-memory {
		q6_mem_regions: q6_mem_regions@4b000000 {
			no-map;
#ifndef CONFIG_ATH11K_MEM_PROFILE_256M
			reg = <0x0 0x4b000000 0x0 0x3b00000>;
#else
			reg = <0x0 0x4b000000 0x0 0x3000000>;
#endif
		};
	};
};

&blsp1_uart1 {
	pinctrl-0 = <&blsp_uart0_pins>;
	pinctrl-names = "default";
	status = "okay";
};

&qpic_bam {
	status = "okay";
};

/* NAND flash configuration */
&nand {
	pinctrl-0 = <&qspi_nand_pins>;
	pinctrl-names = "default";
	status = "okay";
};

&tsens {
	status = "okay";
};

&tlmm {
	blsp_uart0_pins: blsp_uart0_pins {
		pins =
			"gpio28", /* RX */
			"gpio29"; /* TX */
		function = "blsp0_uart1";
		drive-strength = <8>;
		bias-disable;
	};

	qspi_nand_pins: qspi_nand_pins {
		clock {
			pins = "gpio9";
			function = "qspi_clk";
			drive-strength = <8>;
			bias-disable;
		};

		cs {
			pins = "gpio8";
			function = "qspi_cs";
			drive-strength = <8>;
			bias-disable;
		};

		data {
			pins = "gpio7", "gpio6", "gpio5", "gpio4";
			function = "qspi_data";
			drive-strength = <8>;
			bias-disable;
		};
	};

	mdio1_pins: mdio1_pins {
		mdc {
			pins = "gpio36";
			function = "mdc";
			drive-strength = <8>;
			bias-pull-up;
		};

		mdio {
			pins = "gpio37";
			function = "mdio";
			drive-strength = <8>;
			bias-pull-up;
		};
	};

	leds_pins: leds_pins {
		led_status_red {
			pins = "gpio24";
			function = "gpio";
			drive-strength = <8>;
			bias-pull-down;
		};

		led_status_green {
			pins = "gpio19";
			function = "gpio";
			drive-strength = <8>;
			bias-pull-down;
		};

		led_status_blue {
			pins = "gpio17";
			function = "gpio";
			drive-strength = <8>;
			bias-pull-down;
		};
	};

	button_pins: button_pins {
		button_reset {
			pins = "gpio23";
			function = "gpio";
			drive-strength = <8>;
			bias-pull-up;
		};

		button_mesh {
			pins = "gpio38";
			function = "gpio";
			drive-strength = <8>;
			bias-pull-up;
		};
	};
};

&soc {
	leds {
		compatible = "gpio-leds";
		pinctrl-0 = <&leds_pins>;
		pinctrl-names = "default";

		led_status_red: led_status_red {
			label = "red:system";
			gpio = <&tlmm 24 GPIO_ACTIVE_HIGH>;
		};

		led_status_green: led_status_green {
			label = "green:system";
			gpio = <&tlmm 19 GPIO_ACTIVE_HIGH>;
		};

		led_status_blue: led_status_blue {
			label = "blue:internet";
			gpio = <&tlmm 17 GPIO_ACTIVE_HIGH>;
		};
	};

	button {
		compatible = "gpio-keys";
		pinctrl-0 = <&button_pins>;
		pinctrl-names = "default";

		button_reset {
			label = "reset";
			gpios = <&tlmm 23 GPIO_ACTIVE_LOW>;
			linux,input-type = <EV_KEY>;
			linux,code = <KEY_RESTART>;
			debounce-interval = <60>;
		};

		button_mesh {
			label = "mesh";
			gpios = <&tlmm 38 GPIO_ACTIVE_LOW>;
			linux,input-type = <EV_KEY>;
			linux,code = <KEY_WPS_BUTTON>;
			debounce-interval = <60>;
		};
	};
};

&mdio0 {
	status = "okay";

	/* IPQ5018 GE Phy */
	ethernet-phy@7 {
		reg = <7>;
	};
};

&mdio1 {
	pinctrl-0 = <&mdio1_pins>;
	pinctrl-names = "default";
	status = "okay";

	reset-gpios = <&tlmm 26 GPIO_ACTIVE_LOW>;

	/* QCA8337 Phy0 -> WAN */
	ethernet-phy@0 {
		reg = <0>;
	};

	/* QCA8337 Phy1 -> LAN1 */
	ethernet-phy@1 {
		reg = <1>;
	};

	/* QCA8337 Phy2 -> IPQ5018 GE Phy */
	ethernet-phy@2 {
		reg = <2>;
	};

	/* QCA8337 Phy3 -> LAN2 */
	ethernet-phy@3 {
		reg = <3>;
	};

	/* QCA8337 Phy4 -> LAN3 */
	ethernet-phy@4 {
		reg = <4>;
	};
};

&dp1 {
	status = "okay";
	phy-handle = <&ge_phy>;
};

&dp2 {
	status = "okay";
};

&ess_instance {
	num_devices = <2>;
};

/* WiFi configuration - Fixed with proper calibration variant */
&wifi0 {
	qcom,multipd_arch;
	qcom,rproc = <&q6_wcss_pd1>;
	qcom,userpd-subsys-name = "q6v5_wcss_userpd1";

	/* Calibration variant for CMCC RAX3000Q */
	qcom,ath11k-calibration-variant = "CMCC-RAX3000Q";
	
	qcom,board_id = <0x24>;

	qcom,bdf-addr = <0x4c400000 0x4c400000 0x4c400000>;
	qcom,caldb-addr = <0x4d200000 0x4d200000 0>;
#ifndef CONFIG_ATH11K_MEM_PROFILE_256M
	m3-dump-addr = <0x4d400000>;
#else
	m3-dump-addr = <0>;
#endif

	status = "okay";
};

&wifi1 {
	qcom,multipd_arch;
	qcom,rproc = <&q6_wcss_pd2>;
	qcom,userpd-subsys-name = "q6v5_wcss_userpd2";

	/* Calibration variant for CMCC RAX3000Q */
	qcom,ath11k-calibration-variant = "CMCC-RAX3000Q";
	
	qcom,board_id = <0x60>;

	qcom,bdf-addr = <0x4d500000 0x4d500000 0x4d100000>;
	qcom,caldb-addr = <0x4e500000 0x4e500000 0>;
#ifndef CONFIG_ATH11K_MEM_PROFILE_256M
	m3-dump-addr = <0x4ea00000>;
#else
	m3-dump-addr = <0x4df00000>;
#endif

	status = "okay";
};
